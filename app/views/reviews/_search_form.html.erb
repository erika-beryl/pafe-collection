<%= search_form_for q, url: url do |f| %>
  <div class="row g-1 mb-3">
    <div class="col-12 col-md">
      <div data-controller="autocomplete" data-autocomplete-url-value="<%= autocomplete_reviews_path %>" role="combobox">
        <%= f.search_field :title_cont, class: 'form-control', placeholder: "タイトル", data: { autocomplete_target: 'input' } %>
        <%= f.hidden_field :title, data: { autocomplete_target: 'hidden' } %>
        <ul class="list-group" data-autocomplete-target="results"></ul>
      </div>
    </div>
    <div class="col-12 col-md">
      <%= f.search_field :body_cont, class: 'form-control', placeholder: "本文" %>
    </div>
    <div class="col-md-auto">
      <%= f.submit class: 'btn btn-primary' %>
    </div>
  </div>
<% end %>