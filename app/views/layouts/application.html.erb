<!DOCTYPE html>
<html>
  <head>
    <title>パフェコレ</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", preload: false, defer: true, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>

    <%= display_meta_tags(default_meta_tags) %>
  </head>

  <body>
    <div id="raty-config" 
      data-star-half="<%= asset_path('star-half.png') %>"
      data-star-off="<%= asset_path('star-off.png') %>"
      data-star-on="<%= asset_path('star-on.png') %>"
      style="display: none;">
    </div>
    <%= render 'shared/header' %>
    <%= render 'shared/flash_message' %>
    <%= breadcrumbs separator: " &rsaquo; ", class: "breadcrum-wrapper" %>
    <main>
      <%= yield %>
    </main>  
    <%= render 'shared/footer' %>
  </body>
</html>
