<%= search_form_for q, url: url do |f| %>
  <div class="input-group mb-3">
    <%= f.search_field :name_cont, class: 'form-control', placeholder: "店舗名" %>
    <%= f.search_field :full_address_cont, class: 'form-control', placeholder: "住所" %>
    <%= f.submit class: 'btn btn-primary' %>
  </div>
<% end %>