<%= search_form_for q, url: url do |f| %>
  <div class="input-group mb-3">
    <div data-controller="autocomplete" data-autocomplete-url-value="<%= autocomplete_parfaits_path %>" role="combobox">
      <%= f.search_field :name_cont,
            class: 'form-control',
            placeholder: "パフェ名",
            data: { autocomplete_target: 'input' } %>
      <%= f.hidden_field :name, data: { autocomplete_target: 'hidden' } %>
      <ul class="list-group" data-autocomplete-target="results"></ul>
    </div>  
    <%= f.select :price_lteq, Parfait.prices.keys.map { |k| [I18n.t("enums.parfait.price.#{k}"), Parfait.prices[k]] }, { prompt: '価格を選択してください' }, class: 'form-select' %>
    <%= f.select :is_limited_eq,
                  [['すべて', ''], ['期間限定', true], ['レギュラー', false]],
                  { prompt: '期間限定を選択' },
                  class: 'form-select' %>

    <%= f.submit class: 'btn btn-primary' %>
  </div>
<% end %>